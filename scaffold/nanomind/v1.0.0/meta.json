{
  "$schema": "https://gve.dev/schema/meta.json",
  "name": "nanomind",
  "version": "1.0.0",
  "category": "scaffold",
  "description": "NanoMind full-stack scaffold with React + Tailwind + Vite + i18n + sidebar layout.",
  "dest": "site",
  "deps": [],
  "defaultAssets": [
    "components/theme-provider",
    "components/mode-toggle",
    "components/settings-dropdown",
    "components/color-theme-selector",
    "components/locale-switcher",
    "components/api-error-dialog"
  ],
  "files": [
    "embed.go",
    "package.json",
    "vite.config.ts",
    "tsconfig.json",
    "tsconfig.app.json",
    "tsconfig.node.json",
    "biome.json",
    "components.json",
    "index.html",
    "src/vite-env.d.ts",
    "src/app/main.tsx",
    "src/app/App.tsx",
    "src/app/providers.tsx",
    "src/app/styles/globals.css",
    "src/app/layout/index.tsx",
    "src/app/layout/nav-config.ts",
    "src/app/layout/components/app-sidebar.tsx",
    "src/app/layout/components/nav.tsx",
    "src/app/layout/components/nav-user.tsx",
    "src/app/layout/components/site-header.tsx",
    "src/i18n/index.ts",
    "src/i18n/types.ts",
    "src/i18n/locales/en/common.json",
    "src/i18n/locales/en/dashboard.json",
    "src/i18n/locales/en/theme.json",
    "src/i18n/locales/zh-CN/common.json",
    "src/i18n/locales/zh-CN/dashboard.json",
    "src/i18n/locales/zh-CN/theme.json",
    "src/shared/lib/utils.ts",
    "src/shared/hooks/use-api-error.ts",
    "src/shared/hooks/use-locale.ts",
    "src/shared/hooks/use-mobile.ts",
    "src/shared/hooks/use-theme.ts",
    "src/shared/shadcn/.gitkeep",
    "src/shared/types/.gitkeep",
    "src/shared/wk/components/.gitkeep",
    "src/shared/wk/ui/.gitkeep",
    "src/views/home/index.tsx",
    "src/api/README.md"
  ]
}
