  "defaultAssets": [
    "components/theme-provider@1.0.0",
    "components/mode-toggle@2.0.0",
    "components/locale-switcher@2.0.0",
    "components/api-error-dialog@1.1.0"
  ],
  "files": [
    "app.json",
    "embed.go",
    "package.json",
    "vite.config.ts",
    "tsconfig.json",
    "tsconfig.app.json",
    "tsconfig.node.json",
    "biome.json",
    "components.json",
    "index.html",
    "src/vite-env.d.ts",
    "src/app/main.tsx",
    "src/app/App.tsx",
    "src/app/providers.tsx",
    "src/app/styles/globals.css",
    "src/app/layout/index.tsx",
    "src/app/layout/nav-config.ts",
    "src/app/layout/components/app-sidebar.tsx",
    "src/app/layout/components/nav.tsx",
    "src/app/layout/components/nav-user.tsx",
    "src/app/layout/components/site-header.tsx",
