{
  "$schema": "https://gve.dev/schema/meta.json",
  "name": "dashboard-02",
  "version": "1.0.0",
  "category": "scaffold",
  "description": "Dashboard scaffold with React + Tailwind + Vite + i18n + sidebar layout (Hugeicons, icon collapsible, motion animations, Two-Layer Color Architecture).",
