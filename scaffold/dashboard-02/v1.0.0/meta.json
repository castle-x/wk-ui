    "src/shared/hooks/use-locale.ts",
    "src/shared/hooks/use-mobile.ts",
    "src/shared/hooks/use-theme.ts",
    "src/shared/shadcn/avatar.tsx",
    "src/shared/shadcn/button.tsx",
    "src/shared/shadcn/dropdown-menu.tsx",
    "src/shared/shadcn/separator.tsx",
